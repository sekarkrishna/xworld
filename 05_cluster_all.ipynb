import pandas as pd
import numpy as np
from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans
from sklearn.metrics import silhouette_score, adjusted_rand_score
import hdbscan
import umap
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
import seaborn as sns
from pathlib import Path
import warnings
warnings.filterwarnings('ignore')

PROCESSED_DIR = Path('../data/processed')
print('Imports OK')

# Load all feature files
feature_files = [
    'features_covid_first_wave.csv',
    'features_sunspot_cycles.csv',
    'features_lynx_hare.csv',
    'features_keeling.csv',
]

dfs = []
for fname in feature_files:
    path = PROCESSED_DIR / fname
    if path.exists():
        df = pd.read_csv(path)
        dfs.append(df)
        print(f'Loaded {fname}: {len(df)} rows')
    else:
        print(f'MISSING: {fname} — run the corresponding pipeline notebook first')

df_all = pd.concat(dfs, ignore_index=True)
print(f'\nTotal instances: {len(df_all)}')
print('\nPer dataset:')
print(df_all['dataset'].value_counts())

# Prepare feature matrix
FEATURE_COLS = ['skewness', 'kurtosis', 'lag1_autocorr', 'zero_crossings', 'slope']

df_clean = df_all.dropna(subset=FEATURE_COLS).copy()
print(f'Rows after dropping NaN: {len(df_clean)} (dropped {len(df_all) - len(df_clean)})')

X = df_clean[FEATURE_COLS].values

scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

print(f'Feature matrix: {X_scaled.shape}')
print(f'\nPer dataset after cleaning:')
print(df_clean['dataset'].value_counts())

# UMAP
reducer = umap.UMAP(n_components=2, random_state=42, n_neighbors=15, min_dist=0.1)
embedding = reducer.fit_transform(X_scaled)

df_clean = df_clean.copy()
df_clean['umap_x'] = embedding[:, 0]
df_clean['umap_y'] = embedding[:, 1]

print('UMAP done')
print(f'Embedding shape: {embedding.shape}')

# UMAP coloured by DOMAIN
datasets = df_clean['dataset'].unique()
palette = dict(zip(datasets, sns.color_palette('tab10', len(datasets))))

fig, ax = plt.subplots(figsize=(10, 7))
for ds in datasets:
    mask = df_clean['dataset'] == ds
    ax.scatter(
        df_clean.loc[mask, 'umap_x'],
        df_clean.loc[mask, 'umap_y'],
        c=[palette[ds]],
        label=ds,
        alpha=0.6,
        s=30,
        edgecolors='none'
    )

ax.legend(fontsize=9, markerscale=1.5)
ax.set_title('UMAP — Coloured by Dataset (Domain)', fontsize=13)
ax.set_xlabel('UMAP 1')
ax.set_ylabel('UMAP 2')
ax.set_facecolor('#f8f8f8')
plt.tight_layout()
plt.savefig(PROCESSED_DIR / 'umap_by_domain.png', dpi=150, bbox_inches='tight')
plt.show()

print('\nIf each dataset forms a tight separate island → domain dominates')
print('If datasets are mixed/interleaved → dynamic shape dominates')

# HDBSCAN
clusterer = hdbscan.HDBSCAN(min_cluster_size=5, min_samples=3, metric='euclidean')
cluster_labels = clusterer.fit_predict(X_scaled)

df_clean = df_clean.copy()
df_clean['cluster'] = cluster_labels

n_clusters = len(set(cluster_labels)) - (1 if -1 in cluster_labels else 0)
n_noise = (cluster_labels == -1).sum()
print(f'Clusters found: {n_clusters}')
print(f'Noise points (-1): {n_noise} ({100*n_noise/len(cluster_labels):.1f}%)')

print('\nCluster sizes:')
print(pd.Series(cluster_labels).value_counts().sort_index())

# UMAP coloured by CLUSTER
unique_clusters = sorted(df_clean['cluster'].unique())
cluster_palette = {c: 'lightgrey' if c == -1 else sns.color_palette('Set1', n_clusters)[i % n_clusters]
                   for i, c in enumerate(unique_clusters)}

fig, ax = plt.subplots(figsize=(10, 7))
for c in unique_clusters:
    mask = df_clean['cluster'] == c
    label = 'noise' if c == -1 else f'cluster {c}'
    ax.scatter(
        df_clean.loc[mask, 'umap_x'],
        df_clean.loc[mask, 'umap_y'],
        c=[cluster_palette[c]],
        label=label,
        alpha=0.7 if c != -1 else 0.2,
        s=35 if c != -1 else 15,
        edgecolors='none'
    )

ax.legend(fontsize=9, markerscale=1.5)
ax.set_title('UMAP — Coloured by HDBSCAN Cluster (Shape-based)', fontsize=13)
ax.set_xlabel('UMAP 1')
ax.set_ylabel('UMAP 2')
ax.set_facecolor('#f8f8f8')
plt.tight_layout()
plt.savefig(PROCESSED_DIR / 'umap_by_cluster.png', dpi=150, bbox_inches='tight')
plt.show()

# Cross-tabulation: cluster × dataset
crosstab = pd.crosstab(
    df_clean['cluster'],
    df_clean['dataset'],
    margins=True
)
print('Cluster × Dataset composition:')
print(crosstab)
print()

crosstab_pct = pd.crosstab(
    df_clean['cluster'],
    df_clean['dataset'],
    normalize='index'
).round(2)
print('Cluster composition (% of each cluster):')
print(crosstab_pct)

# Adjusted Rand Index
domain_int = pd.factorize(df_clean['dataset'])[0]
non_noise = df_clean['cluster'] != -1

ari = adjusted_rand_score(
    domain_int[non_noise],
    df_clean.loc[non_noise, 'cluster']
)

print(f'Adjusted Rand Index (cluster vs domain): {ari:.3f}')
print()
print('Interpretation:')
print('  ARI = 1.0  → clusters match domains perfectly (domain determines everything)')
print('  ARI = 0.0  → clusters are random w.r.t. domains')
print('  ARI < 0.3  → clusters cut meaningfully across domains → dynamic shape dominates')
print()
if ari < 0.3:
    print('>>> Shape clusters are largely domain-independent. The hypothesis holds.')
elif ari < 0.6:
    print('>>> Mixed result — some domain structure, some shape structure crossing domains.')
else:
    print('>>> Domain is the dominant organising principle. More diverse data needed.')

# Feature profile per cluster
cluster_profiles = df_clean[df_clean['cluster'] != -1].groupby('cluster')[FEATURE_COLS].mean().round(3)
print('Mean feature values per cluster:')
print(cluster_profiles)

